        },
        {
            "src": "api/test_diagnostics.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "assets/**",
            "use": "@vercel/static"
        },
        {
            "src": "index.html",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/assets/$1",
            "headers": {
                "Cache-Control": "public, max-age=31536000, immutable"
            }
        },
        {
            "src": "/api/(.*)\\.php",
            "dest": "/api/$1.php"
        },
        {
            "src": "/(.*)\\.php",
            "dest": "/$1.php"
        },
        {
            "src": "/",
            "dest": "/index.php"
        }
    ]
}